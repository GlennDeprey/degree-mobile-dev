<?xml version="1.0" encoding="utf-8" ?>
<base:SfContentPage
    x:Class="Mde.Project.Mobile.Pages.App.Statistics.StatisticsPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:base="clr-namespace:Mde.Project.Mobile.Controls.Base"
    xmlns:controls="clr-namespace:Mde.Project.Mobile.Controls"
    xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.Maui;assembly=LiveChartsCore.SkiaSharpView.Maui"
    xmlns:m="clr-namespace:UraniumUI.Icons.MaterialIcons;assembly=UraniumUI.Icons.MaterialIcons"
    xmlns:material="http://schemas.enisn-projects.io/dotnet/maui/uraniumui/material"
    xmlns:skia="clr-namespace:SkiaSharp.Extended.UI.Controls;assembly=SkiaSharp.Extended.UI"
    xmlns:statistics="clr-namespace:Mde.Project.Mobile.ViewModels.App.Statistics"
    xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
    Title="Statistics"
    x:DataType="statistics:StatisticsViewModel">
    <base:SfContentPage.Behaviors>
        <toolkit:EventToCommandBehavior Command="{Binding InitializeCommand}" EventName="Appearing" />
    </base:SfContentPage.Behaviors>
    <base:SfContentPage.ToolbarItems>
        <ToolbarItem
            Command="{Binding ProfileNavigationCommand}"
            Order="Primary"
            Priority="1">
            <ToolbarItem.IconImageSource>
                <FontImageSource
                    FontFamily="MaterialRegular"
                    Glyph="{x:Static m:MaterialRegular.Account_circle}"
                    Color="{AppThemeBinding Light={StaticResource Charcoal},
                                            Dark={StaticResource Warehouse}}" />
            </ToolbarItem.IconImageSource>
        </ToolbarItem>
        <controls:SfToolBarItem
            Command="{Binding HomeNavigationCommand}"
            Order="Primary"
            Priority="0">
            <!--  IsVisible="{Binding IsAdmin}"  -->
            <ToolbarItem.IconImageSource>
                <FontImageSource
                    FontFamily="MaterialRegular"
                    Glyph="{x:Static m:MaterialRegular.Home}"
                    Color="{AppThemeBinding Light={StaticResource Charcoal},
                                            Dark={StaticResource Warehouse}}" />
            </ToolbarItem.IconImageSource>
        </controls:SfToolBarItem>
    </base:SfContentPage.ToolbarItems>
    <ScrollView>
        <VerticalStackLayout Padding="10">
            <Grid
                Margin="10"
                MaximumWidthRequest="900"
                RowDefinitions="200, *">
                <Grid
                    Grid.Row="0"
                    Margin="0,0,0,30"
                    HeightRequest="200"
                    WidthRequest="200">
                    <skia:SKLottieView
                        Margin="0,10,0,0"
                        HeightRequest="150"
                        IsVisible="True"
                        RepeatCount="-1"
                        Scale="1"
                        Source="dashboard_stats.json" />
                </Grid>
                <Grid Grid.Row="1" Margin="0,0,0,50">
                    <ActivityIndicator
                        HorizontalOptions="Center"
                        IsRunning="{Binding IsBusy}"
                        IsVisible="{Binding IsBusy}"
                        VerticalOptions="Center" />
                    <VerticalStackLayout
                        Padding="10"
                        IsVisible="{Binding IsBusy, Converter={toolkit:InvertedBoolConverter}}"
                        Spacing="20">
                        <material:PickerField
                            Title="Select a warehouse"
                            AccentColor="{AppThemeBinding Light={StaticResource Cerulean},
                                                          Dark={StaticResource BlueMunself}}"
                            AllowClear="False"
                            Icon="{FontImageSource FontFamily=MaterialRegular,
                                                   Glyph={x:Static m:MaterialRegular.Warehouse}}"
                            ItemDisplayBinding="{Binding Name}"
                            ItemsSource="{Binding Warehouses}"
                            SelectedItem="{Binding SelectedWarehouse}"
                            SelectedValueChangedCommand="{Binding WarehouseChangedCommand}"
                            VerticalOptions="Center" />
                        <Border
                            Padding="20"
                            BackgroundColor="{AppThemeBinding Light={StaticResource Gray100},
                                                              Dark={StaticResource LightJet}}"
                            Stroke="{StaticResource Jet}"
                            StrokeShape="RoundRectangle 30,30,30,30">
                            <VerticalStackLayout>
                                <HorizontalStackLayout
                                    HorizontalOptions="Center"
                                    Spacing="6"
                                    VerticalOptions="Center">
                                    <Image>
                                        <Image.Source>
                                            <FontImageSource
                                                FontFamily="MaterialRegular"
                                                Glyph="{x:Static m:MaterialRegular.Shopping_cart}"
                                                Size="30"
                                                Color="{AppThemeBinding Dark={StaticResource Gray100},
                                                                        Light={StaticResource Charcoal}}" />
                                        </Image.Source>
                                    </Image>
                                    <Label
                                        FontAttributes="Bold"
                                        FontSize="20"
                                        Text="Latest Sales Info" />
                                </HorizontalStackLayout>
                                <OnPlatform x:TypeArguments="View">
                                    <On Platform="Android">
                                        <lvc:CartesianChart
                                            Margin="0,10,0,0"
                                            HeightRequest="400"
                                            HorizontalOptions="End"
                                            IsVisible="{Binding IsWarehouseStatsLoaded}"
                                            Series="{Binding LatestSalesInfo.Series}"
                                            WidthRequest="300"
                                            XAxes="{Binding LatestSalesInfo.XAxes}"
                                            YAxes="{Binding LatestSalesInfo.YAxes}"
                                            ZoomMode="X" />
                                    </On>
                                    <On Platform="WinUI">
                                        <lvc:CartesianChart
                                            HeightRequest="400"
                                            HorizontalOptions="Center"
                                            IsVisible="{Binding IsWarehouseStatsLoaded}"
                                            Series="{Binding LatestSalesInfo.Series}"
                                            WidthRequest="820"
                                            XAxes="{Binding LatestSalesInfo.XAxes}"
                                            YAxes="{Binding LatestSalesInfo.YAxes}"
                                            ZoomMode="PanX" />
                                    </On>
                                </OnPlatform>
                            </VerticalStackLayout>
                        </Border>
                    </VerticalStackLayout>
                </Grid>
            </Grid>
        </VerticalStackLayout>
    </ScrollView>

</base:SfContentPage>