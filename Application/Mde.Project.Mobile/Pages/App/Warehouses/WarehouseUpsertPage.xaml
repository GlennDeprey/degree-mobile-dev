<?xml version="1.0" encoding="utf-8" ?>
<base:SfContentPage
    x:Class="Mde.Project.Mobile.Pages.App.Warehouses.WarehouseUpsertPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:base="clr-namespace:Mde.Project.Mobile.Controls.Base"
    xmlns:controls="clr-namespace:InputKit.Shared.Controls;assembly=InputKit.Maui"
    xmlns:m="http://schemas.enisn-projects.io/dotnet/maui/uraniumui"
    xmlns:material="http://schemas.enisn-projects.io/dotnet/maui/uraniumui/material"
    xmlns:validations="clr-namespace:InputKit.Shared.Validations;assembly=InputKit.Maui"
    xmlns:vm="clr-namespace:Mde.Project.Mobile.ViewModels.App.Warehouses"
    Title="{Binding Title}"
    x:DataType="vm:WarehouseUpsertViewModel">
    <ScrollView>
        <Grid RowDefinitions="200,*">
            <Grid
                Grid.Row="0"
                Margin="0,0,0,30"
                HeightRequest="100"
                WidthRequest="100">
                <Border
                    BackgroundColor="{AppThemeBinding Dark={StaticResource Jet},
                                                      Light={StaticResource LightBackground}}"
                    HorizontalOptions="Center"
                    Stroke="{AppThemeBinding Dark={StaticResource LightJet},
                                             Light={StaticResource Gray100}}"
                    StrokeShape="RoundRectangle 50">
                    <Image Aspect="AspectFill" Source="{Binding ImageUrl}" />
                </Border>
            </Grid>

            <Grid
                Grid.Row="1"
                MaximumWidthRequest="900"
                StyleClass="Elevation1">
                <Border
                    Margin="-5,-40,-5,-2"
                    Stroke="Transparent"
                    StrokeShape="RoundRectangle 30,30,0,0">
                    <Grid>
                        <RoundRectangle CornerRadius="30,30,0,0" Fill="{AppThemeBinding Dark={StaticResource Jet}, Light={StaticResource LightBackground}}" />
                        <VerticalStackLayout Padding="20,20,20,50">
                            <Label
                                Margin="0,0,0,20"
                                FontSize="18"
                                HorizontalOptions="Center"
                                TextColor="{StaticResource Gray300}">
                                Warehouse Info
                            </Label>
                            <ActivityIndicator
                                HorizontalOptions="Center"
                                IsRunning="{Binding IsBusy}"
                                IsVisible="{Binding IsBusy}"
                                VerticalOptions="Center" />
                            <controls:FormView Spacing="20" SubmitCommand="{Binding UpsertWarehouseCommand}">
                                <material:TextField
                                    Title="Name"
                                    AccentColor="{AppThemeBinding Dark={StaticResource BlueMunself},
                                                                  Light={StaticResource Cerulean}}"
                                    Icon="{FontImageSource FontFamily=MaterialRegular,
                                                           Glyph={x:Static m:MaterialRegular.Text_fields}}"
                                    Text="{Binding Warehouse.Name}">
                                    <validations:RequiredValidation />
                                </material:TextField>
                                <material:TextField
                                    Title="Short Name"
                                    AccentColor="{AppThemeBinding Dark={StaticResource BlueMunself},
                                                                  Light={StaticResource Cerulean}}"
                                    Icon="{FontImageSource FontFamily=MaterialRegular,
                                                           Glyph={x:Static m:MaterialRegular.Short_text}}"
                                    Text="{Binding Warehouse.ShortName}">
                                    <validations:RequiredValidation />
                                </material:TextField>
                                <material:TextField
                                    Title="Phone Number"
                                    AccentColor="{AppThemeBinding Dark={StaticResource BlueMunself},
                                                                  Light={StaticResource Cerulean}}"
                                    Icon="{FontImageSource FontFamily=MaterialRegular,
                                                           Glyph={x:Static m:MaterialRegular.Phone}}"
                                    Keyboard="Numeric"
                                    Text="{Binding Warehouse.Phone}">
                                    <validations:RequiredValidation />
                                </material:TextField>
                                <material:AutoCompleteTextField
                                    Title="Address"
                                    AccentColor="{AppThemeBinding Dark={StaticResource BlueMunself},
                                                                  Light={StaticResource Cerulean}}"
                                    Icon="{FontImageSource FontFamily=MaterialRegular,
                                                           Glyph={x:Static m:MaterialRegular.Location_city}}"
                                    ItemsSource="{Binding AutoCompleteText}"
                                    Text="{Binding SelectedAutoCompleteText}"
                                    TextChanged="AutoCompleteTextField_OnTextChanged">
                                    <material:AutoCompleteTextField.Validations>
                                        <validations:RequiredValidation />
                                    </material:AutoCompleteTextField.Validations>
                                </material:AutoCompleteTextField>
                                <Button
                                    controls:FormView.IsSubmitButton="True"
                                    BackgroundColor="YellowGreen"
                                    StyleClass="FilledButton"
                                    Text="{Binding Title}"
                                    TextColor="{StaticResource GhostWhite}" />
                            </controls:FormView>
                        </VerticalStackLayout>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </ScrollView>
</base:SfContentPage>