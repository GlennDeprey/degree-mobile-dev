<?xml version="1.0" encoding="utf-8" ?>
<base:SfContentPage
    x:Class="Mde.Project.Mobile.Pages.App.Products.CategoryDetailPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:base="clr-namespace:Mde.Project.Mobile.Controls.Base"
    xmlns:controls="clr-namespace:Mde.Project.Mobile.Controls"
    xmlns:converters="clr-namespace:Mde.Project.Mobile.Converters"
    xmlns:m="clr-namespace:UraniumUI.Icons.MaterialIcons;assembly=UraniumUI.Icons.MaterialIcons"
    xmlns:skia="clr-namespace:SkiaSharp.Extended.UI.Controls;assembly=SkiaSharp.Extended.UI"
    xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
    xmlns:vm="clr-namespace:Mde.Project.Mobile.ViewModels.App.Products"
    Title="Category Detail"
    x:DataType="vm:CategoryDetailViewModel">
    <base:SfContentPage.ToolbarItems>
        <controls:SfToolBarItem
            Command="{Binding CategoryEditNavigationCommand}"
            CommandParameter="{Binding Category.Id}"
            Order="Primary"
            Priority="1">
            <!--  IsVisible="{Binding IsAdmin}"  -->
            <ToolbarItem.IconImageSource>
                <FontImageSource
                    FontFamily="MaterialRegular"
                    Glyph="{x:Static m:MaterialRegular.Edit}"
                    Color="{AppThemeBinding Dark={StaticResource Gray300},
                                            Light={StaticResource Charcoal}}" />
            </ToolbarItem.IconImageSource>
        </controls:SfToolBarItem>
        <controls:SfToolBarItem
            Command="{Binding CategoryDeleteNavigationCommand}"
            CommandParameter="{Binding Category.Id}"
            Order="Primary"
            Priority="0">
            <!--  IsVisible="{Binding IsAdmin}"  -->
            <ToolbarItem.IconImageSource>
                <FontImageSource
                    FontFamily="MaterialRegular"
                    Glyph="{x:Static m:MaterialRegular.Delete}"
                    Color="IndianRed" />
            </ToolbarItem.IconImageSource>
        </controls:SfToolBarItem>
    </base:SfContentPage.ToolbarItems>
    <ScrollView>
        <VerticalStackLayout>
            <ActivityIndicator
                HorizontalOptions="Center"
                IsRunning="{Binding IsBusy}"
                IsVisible="{Binding IsBusy}"
                VerticalOptions="Center" />
            <Grid IsVisible="{Binding IsBusy, Converter={toolkit:InvertedBoolConverter}}" RowDefinitions="200,*">
                <Grid
                    Grid.Row="0"
                    Margin="0,0,0,50"
                    HeightRequest="200"
                    WidthRequest="200">
                    <Grid
                        Grid.Row="0"
                        Margin="0,30,0,30"
                        HeightRequest="200"
                        WidthRequest="200">
                        <skia:SKLottieView
                            Margin="0,10,0,0"
                            HeightRequest="150"
                            IsVisible="True"
                            RepeatCount="-1"
                            Scale="1"
                            Source="categorys_book.json" />
                    </Grid>
                </Grid>

                <Grid
                    Grid.Row="1"
                    Margin="0,0,0,50"
                    MaximumWidthRequest="900">
                    <VerticalStackLayout Spacing="10">
                        <Border
                            Margin="20,0,20,0"
                            Padding="20"
                            BackgroundColor="{AppThemeBinding Dark={StaticResource Jet},
                                                              Light={StaticResource LightBackground}}"
                            Stroke="{AppThemeBinding Dark={StaticResource LightJet},
                                                     Light={StaticResource Gray100}}"
                            StrokeShape="RoundRectangle 10">
                            <VerticalStackLayout Spacing="10">
                                <HorizontalStackLayout Spacing="5">
                                    <Image HorizontalOptions="Center" VerticalOptions="Center">
                                        <Image.Source>
                                            <FontImageSource
                                                FontFamily="MaterialRegular"
                                                Glyph="{x:Static m:MaterialRegular.Text_fields}"
                                                Size="23"
                                                Color="{AppThemeBinding Dark={StaticResource Gray100},
                                                                        Light={StaticResource Charcoal}}" />
                                        </Image.Source>
                                    </Image>
                                    <Label
                                        FontAttributes="Bold"
                                        HorizontalOptions="Center"
                                        TextColor="{AppThemeBinding Dark={StaticResource Gray100},
                                                                    Light={StaticResource Charcoal}}"
                                        VerticalOptions="Center">
                                        Name:
                                    </Label>
                                    <Label
                                        Margin="10,0,0,0"
                                        HorizontalOptions="Center"
                                        Text="{Binding Category.Name}"
                                        TextColor="{AppThemeBinding Dark={StaticResource Gray100},
                                                                    Light={StaticResource Charcoal}}"
                                        VerticalOptions="Center" />
                                </HorizontalStackLayout>
                            </VerticalStackLayout>
                        </Border>
                        <Border
                            Margin="20,0,20,0"
                            Padding="20"
                            BackgroundColor="{AppThemeBinding Dark={StaticResource Jet},
                                                              Light={StaticResource LightBackground}}"
                            Stroke="{AppThemeBinding Dark={StaticResource LightJet},
                                                     Light={StaticResource Gray100}}"
                            StrokeShape="RoundRectangle 10">
                            <VerticalStackLayout Spacing="10">
                                <HorizontalStackLayout Spacing="5">
                                    <Image HorizontalOptions="Center" VerticalOptions="Center">
                                        <Image.Source>
                                            <FontImageSource
                                                FontFamily="MaterialRegular"
                                                Glyph="{x:Static m:MaterialRegular.Inventory}"
                                                Size="23"
                                                Color="{AppThemeBinding Dark={StaticResource Gray100},
                                                                        Light={StaticResource Charcoal}}" />
                                        </Image.Source>
                                    </Image>
                                    <Label
                                        FontAttributes="Bold"
                                        HorizontalOptions="Center"
                                        TextColor="{AppThemeBinding Dark={StaticResource Gray100},
                                                                    Light={StaticResource Charcoal}}"
                                        VerticalOptions="Center">
                                        Products:
                                    </Label>
                                    <Label
                                        Margin="10,0,0,0"
                                        HorizontalOptions="Center"
                                        Text="{Binding Category.TotalProducts, Converter={converters:ProductCountToStringConverter}}"
                                        TextColor="{AppThemeBinding Dark={StaticResource Gray100},
                                                                    Light={StaticResource Charcoal}}"
                                        VerticalOptions="Center" />
                                </HorizontalStackLayout>
                            </VerticalStackLayout>
                        </Border>
                    </VerticalStackLayout>
                </Grid>
            </Grid>
        </VerticalStackLayout>
    </ScrollView>
</base:SfContentPage>