<?xml version="1.0" encoding="utf-8" ?>
<base:SfContentPage
    x:Class="Mde.Project.Mobile.Pages.App.Operations.StockTransferPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:base="clr-namespace:Mde.Project.Mobile.Controls.Base"
    xmlns:controls="clr-namespace:Mde.Project.Mobile.Controls"
    xmlns:converters="clr-namespace:Mde.Project.Mobile.Converters"
    xmlns:input="clr-namespace:InputKit.Shared.Controls;assembly=InputKit.Maui"
    xmlns:m="clr-namespace:UraniumUI.Icons.MaterialIcons;assembly=UraniumUI.Icons.MaterialIcons"
    xmlns:material="http://schemas.enisn-projects.io/dotnet/maui/uraniumui/material"
    xmlns:products="clr-namespace:Mde.Project.Mobile.Models.Products"
    xmlns:skia="clr-namespace:SkiaSharp.Extended.UI.Controls;assembly=SkiaSharp.Extended.UI"
    xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
    xmlns:vm="clr-namespace:Mde.Project.Mobile.ViewModels.App.Operations"
    xmlns:warehouse="clr-namespace:Mde.Project.Mobile.Models.Warehouse"
    Title="Stock Transfers"
    x:DataType="vm:StockTransferViewModel">
    <base:SfContentPage.Resources>
        <converters:IsSelectedWarehouseConverter x:Key="IsSelectedWarehouseConverter" />
    </base:SfContentPage.Resources>
    <base:SfContentPage.Behaviors>
        <toolkit:EventToCommandBehavior Command="{Binding InitializeCommand}"
                                        EventName="Appearing" />
    </base:SfContentPage.Behaviors>
    <base:SfContentPage.ToolbarItems>
        <ToolbarItem
            Command="{Binding ProfileNavigationCommand}"
            Order="Primary"
            Priority="1">
            <ToolbarItem.IconImageSource>
                <FontImageSource
                    FontFamily="MaterialRegular"
                    Glyph="{x:Static m:MaterialRegular.Account_circle}"
                    Color="{AppThemeBinding Light={StaticResource Charcoal},
                                            Dark={StaticResource Warehouse}}" />
            </ToolbarItem.IconImageSource>
        </ToolbarItem>
        <controls:SfToolBarItem
            Command="{Binding HomeNavigationCommand}"
            IsVisible="{Binding IsAdmin}"
            Order="Primary"
            Priority="0">
            <ToolbarItem.IconImageSource>
                <FontImageSource
                    FontFamily="MaterialRegular"
                    Glyph="{x:Static m:MaterialRegular.Home}"
                    Color="{AppThemeBinding Light={StaticResource Charcoal},
                                            Dark={StaticResource Warehouse}}" />
            </ToolbarItem.IconImageSource>
        </controls:SfToolBarItem>
    </base:SfContentPage.ToolbarItems>
    <ScrollView>
        <VerticalStackLayout Padding="10">
            <ActivityIndicator
                HorizontalOptions="Center"
                IsRunning="{Binding IsBusy}"
                IsVisible="{Binding IsBusy}"
                VerticalOptions="Center" />
            <Grid
                Margin="5,5,5,5"
                IsVisible="{Binding IsBusy, Converter={toolkit:InvertedBoolConverter}}"
                MaximumWidthRequest="900"
                RowDefinitions="150,*">
                <Grid
                    Grid.Row="0"
                    Margin="0,20,0,30"
                    HeightRequest="150"
                    WidthRequest="150">
                    <skia:SKLottieView
                        Margin="0,10,0,0"
                        HeightRequest="150"
                        IsVisible="True"
                        RepeatCount="-1"
                        Scale="1"
                        Source="operations_transfer.json" />
                </Grid>
                <Grid Grid.Row="1" Margin="0,0,0,50">
                    <VerticalStackLayout>
                        <input:FormView
                            IsVisible="{Binding IsBusy, Converter={toolkit:InvertedBoolConverter}}"
                            Spacing="20"
                            SubmitCommand="{Binding SendStockTransferCommand}">
                            <material:PickerField
                                Title="Select a destination"
                                AccentColor="{AppThemeBinding Light={StaticResource Cerulean},
                                                              Dark={StaticResource BlueMunself}}"
                                AllowClear="False"
                                Icon="{FontImageSource FontFamily=MaterialRegular,
                                                       Glyph={x:Static m:MaterialRegular.Warehouse}}"
                                IsEnabled="{Binding IsSearchResultVisible, Converter={toolkit:InvertedBoolConverter}}"
                                ItemDisplayBinding="{Binding Name}"
                                ItemsSource="{Binding Warehouses}"
                                SelectedItem="{Binding DestinationWarehouse}"
                                VerticalOptions="Center" />
                            <material:AutoCompleteTextField
                                Title="Search a product..."
                                AccentColor="{AppThemeBinding Dark={StaticResource BlueMunself},
                                                              Light={StaticResource Cerulean}}"
                                Icon="{FontImageSource FontFamily=MaterialRegular,
                                                       Glyph={x:Static m:MaterialRegular.Search}}"
                                IsEnabled="{Binding IsSearchResultVisible, Converter={toolkit:InvertedBoolConverter}}"
                                ItemsSource="{Binding FilteredProductsNames}"
                                Text="{Binding SelectedProductName}"
                                TextChanged="AutoCompleteTextField_OnTextChanged" />
                            <material:TextField
                                Title="Quantity"
                                AccentColor="{AppThemeBinding Dark={StaticResource BlueMunself},
                                                              Light={StaticResource Cerulean}}"
                                Icon="{FontImageSource FontFamily=MaterialRegular,
                                                       Glyph={x:Static m:MaterialRegular.Add}}"
                                IsEnabled="{Binding IsSearchResultVisible, Converter={toolkit:InvertedBoolConverter}}"
                                Keyboard="Numeric"
                                Text="{Binding QuantityToSend, Mode=TwoWay}"
                                VerticalOptions="Center" />
                            <material:ButtonView
                                BackgroundColor="{StaticResource Charcoal}"
                                IsVisible="{Binding IsSearchResultVisible, Converter={toolkit:InvertedBoolConverter}}"
                                StyleClass="FilledButton"
                                TappedCommand="{Binding FindWarehousesWithStockCommand}">
                                <HorizontalStackLayout HorizontalOptions="Center" Spacing="5">
                                    <Image
                                        Aspect="AspectFit"
                                        HeightRequest="20"
                                        Source="{FontImageSource FontFamily=MaterialRegular,
                                                                 Glyph={x:Static m:MaterialRegular.Search}}"
                                        VerticalOptions="Center"
                                        WidthRequest="20" />
                                    <Label
                                        FontAttributes="Bold"
                                        Text="Search Warehouses"
                                        TextColor="White"
                                        VerticalOptions="Center" />
                                </HorizontalStackLayout>
                            </material:ButtonView>

                            <Label
                                Margin="0,20,0,0"
                                FontAttributes="Bold"
                                FontSize="16"
                                HorizontalOptions="Center"
                                IsVisible="{Binding IsSearchResultVisible}"
                                Text="Please select the source warehouse"
                                TextColor="White"
                                VerticalOptions="Center" />
                            <BoxView
                                Margin="0"
                                IsVisible="{Binding IsSearchResultVisible}"
                                StyleClass="Divider" />

                            <CollectionView
                                IsVisible="{Binding IsSearchResultVisible}"
                                ItemsSource="{Binding FilteredSenderWarehouses}"
                                MaximumWidthRequest="880"
                                SelectionMode="None">
                                <CollectionView.ItemTemplate>
                                    <DataTemplate x:DataType="warehouse:WarehouseItemModel">
                                        <Border
                                            Margin="10"
                                            Padding="10"
                                            BackgroundColor="{AppThemeBinding Dark={StaticResource Jet},
                                                                              Light={StaticResource LightBackground}}"
                                            MaximumWidthRequest="860"
                                            Stroke="{AppThemeBinding Dark={StaticResource LightJet},
                                                                     Light={StaticResource Gray100}}"
                                            StrokeShape="RoundRectangle 10"
                                            StrokeThickness="1">
                                            <Border.GestureRecognizers>
                                                <TapGestureRecognizer Command="{Binding BindingContext.SelectSenderWarehouseCommand, Source={RelativeSource AncestorType={x:Type ContentPage}}}" CommandParameter="{Binding .}" />
                                            </Border.GestureRecognizers>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <VerticalStackLayout Grid.Column="0">
                                                    <Label
                                                        FontAttributes="Bold"
                                                        Text="{Binding Name}"
                                                        TextColor="{AppThemeBinding Dark={StaticResource Gray100},
                                                                                    Light={StaticResource Jet}}" />
                                                    <Border
                                                        Margin="0,5,0,0"
                                                        Padding="6,3"
                                                        BackgroundColor="{Binding Quantity, Converter={converters:QuantityColorConverter}}"
                                                        HorizontalOptions="Start"
                                                        Stroke="{Binding Quantity, Converter={converters:QuantityToStrokeColorConverter}}"
                                                        StrokeShape="RoundRectangle 12">
                                                        <HorizontalStackLayout Spacing="4">
                                                            <Image HeightRequest="14" WidthRequest="14">
                                                                <Image.Source>
                                                                    <FontImageSource
                                                                        FontFamily="MaterialRegular"
                                                                        Glyph="{x:Static m:MaterialRegular.Inventory_2}"
                                                                        Color="White" />
                                                                </Image.Source>
                                                            </Image>
                                                            <Label
                                                                FontSize="14"
                                                                Text="Quantity : "
                                                                TextColor="White"
                                                                VerticalOptions="Center" />
                                                            <Label
                                                                FontAttributes="Bold"
                                                                FontSize="14"
                                                                Text="{Binding Quantity}"
                                                                TextColor="White"
                                                                VerticalOptions="Center" />
                                                        </HorizontalStackLayout>
                                                    </Border>
                                                </VerticalStackLayout>
                                                <Image
                                                    Grid.Column="1"
                                                    Margin="10"
                                                    HeightRequest="24"
                                                    HorizontalOptions="End"
                                                    VerticalOptions="Start"
                                                    WidthRequest="24">
                                                    <Image.IsVisible>
                                                        <MultiBinding Converter="{StaticResource IsSelectedWarehouseConverter}">
                                                            <Binding Path="BindingContext.SenderWarehouse" Source="{RelativeSource AncestorType={x:Type ContentPage}}" />
                                                            <Binding />
                                                        </MultiBinding>
                                                    </Image.IsVisible>
                                                    <Image.Source>
                                                        <FontImageSource
                                                            FontFamily="MaterialRegular"
                                                            Glyph="{x:Static m:MaterialRegular.Check}"
                                                            Color="{StaticResource YellowGreen}" />
                                                    </Image.Source>
                                                </Image>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </CollectionView.ItemTemplate>
                            </CollectionView>
                            <HorizontalStackLayout
                                Margin="15"
                                HorizontalOptions="End"
                                Spacing="5">
                                <material:ButtonView
                                    BackgroundColor="{StaticResource Cerulean}"
                                    IsVisible="{Binding IsSearchResultVisible}"
                                    StyleClass="FilledButton"
                                    TappedCommand="{Binding ResetSearchStateCommand}">
                                    <HorizontalStackLayout HorizontalOptions="Center" Spacing="5">
                                        <Image
                                            Aspect="AspectFit"
                                            HeightRequest="20"
                                            Source="{FontImageSource FontFamily=MaterialRegular,
                                                                     Glyph={x:Static m:MaterialRegular.Cancel}}"
                                            VerticalOptions="Center"
                                            WidthRequest="20" />
                                        <Label
                                            FontAttributes="Bold"
                                            Text="Reset Search"
                                            TextColor="White"
                                            VerticalOptions="Center" />
                                    </HorizontalStackLayout>
                                </material:ButtonView>
                                <material:ButtonView
                                    input:FormView.IsSubmitButton="True"
                                    BackgroundColor="{StaticResource YellowGreen}"
                                    IsVisible="{Binding IsSearchResultVisible}"
                                    StyleClass="FilledButton">
                                    <HorizontalStackLayout HorizontalOptions="Center" Spacing="5">
                                        <Image
                                            Aspect="AspectFit"
                                            HeightRequest="20"
                                            Source="{FontImageSource FontFamily=MaterialRegular,
                                                                     Glyph={x:Static m:MaterialRegular.Send}}"
                                            VerticalOptions="Center"
                                            WidthRequest="20" />
                                        <Label
                                            FontAttributes="Bold"
                                            Text="Transfer Product"
                                            TextColor="White"
                                            VerticalOptions="Center" />
                                    </HorizontalStackLayout>
                                </material:ButtonView>
                            </HorizontalStackLayout>
                        </input:FormView>
                    </VerticalStackLayout>
                </Grid>
            </Grid>
        </VerticalStackLayout>
    </ScrollView>
</base:SfContentPage>