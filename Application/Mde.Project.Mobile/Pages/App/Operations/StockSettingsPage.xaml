<?xml version="1.0" encoding="utf-8" ?>
<base:SfContentPage
    x:Class="Mde.Project.Mobile.Pages.App.Operations.StockSettingsPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:base="clr-namespace:Mde.Project.Mobile.Controls.Base"
    xmlns:converters="clr-namespace:Mde.Project.Mobile.Converters"
    xmlns:input="clr-namespace:InputKit.Shared.Controls;assembly=InputKit.Maui"
    xmlns:m="clr-namespace:UraniumUI.Icons.MaterialIcons;assembly=UraniumUI.Icons.MaterialIcons"
    xmlns:material="http://schemas.enisn-projects.io/dotnet/maui/uraniumui/material"
    xmlns:skia="clr-namespace:SkiaSharp.Extended.UI.Controls;assembly=SkiaSharp.Extended.UI"
    xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
    xmlns:vm="clr-namespace:Mde.Project.Mobile.ViewModels.App.Operations"
    Title="Stock Settings"
    x:DataType="vm:StockSettingsViewModel">
    <ScrollView>
        <VerticalStackLayout Padding="10">
            <ActivityIndicator
                HorizontalOptions="Center"
                IsRunning="{Binding IsBusy}"
                IsVisible="{Binding IsBusy}"
                VerticalOptions="Center" />
            <Grid
                Margin="5,5,5,5"
                IsVisible="{Binding IsBusy, Converter={toolkit:InvertedBoolConverter}}"
                MaximumWidthRequest="900"
                RowDefinitions="150,*">
                <Grid
                    Grid.Row="0"
                    Margin="0,20,0,30"
                    HeightRequest="150"
                    WidthRequest="150">
                    <skia:SKLottieView
                        Margin="0,10,0,0"
                        HeightRequest="150"
                        IsVisible="True"
                        RepeatCount="-1"
                        Scale="1"
                        Source="operations_settings.json" />
                </Grid>
                <Grid Grid.Row="1" Margin="0,0,0,50">
                    <VerticalStackLayout>
                        <Border
                            Margin="0,0,0,30"
                            BackgroundColor="{AppThemeBinding Dark={StaticResource Jet},
                                                              Light={StaticResource LightBackground}}"
                            MaximumWidthRequest="900"
                            Stroke="{AppThemeBinding Dark={StaticResource LightJet},
                                                     Light={StaticResource Gray100}}"
                            StrokeShape="RoundRectangle 10"
                            StrokeThickness="1">
                            <Grid
                                Padding="10,10,10,10"
                                ColumnDefinitions="100, *"
                                ColumnSpacing="10"
                                HeightRequest="125">
                                <Border
                                    Grid.Column="0"
                                    BackgroundColor="Transparent"
                                    HeightRequest="100"
                                    Stroke="Transparent"
                                    StrokeShape="RoundRectangle 16"
                                    WidthRequest="100">
                                    <Image
                                        Aspect="AspectFill"
                                        HeightRequest="100"
                                        Source="{Binding Item.Product.ImageSource}"
                                        WidthRequest="100" />
                                </Border>
                                <VerticalStackLayout
                                    Grid.Column="1"
                                    Spacing="3"
                                    VerticalOptions="Center">
                                    <Label Text="{Binding Item.Product.Brand.Name}" TextColor="{StaticResource Gray300}" />
                                    <Label
                                        FontSize="14"
                                        Text="{Binding Item.Product.Name}"
                                        TextColor="{AppThemeBinding Dark={StaticResource Gray100},
                                                                    Light={StaticResource Jet}}" />
                                    <HorizontalStackLayout Spacing="5">
                                        <Border
                                            Margin="0,5,0,0"
                                            Padding="6,3"
                                            BackgroundColor="{StaticResource Charcoal}"
                                            HorizontalOptions="Start"
                                            Stroke="{StaticResource Cerulean}"
                                            StrokeShape="RoundRectangle 12">
                                            <HorizontalStackLayout Spacing="4">
                                                <Image HeightRequest="14" WidthRequest="14">
                                                    <Image.Source>
                                                        <FontImageSource
                                                            FontFamily="MaterialRegular"
                                                            Glyph="{x:Static m:MaterialRegular.Category}"
                                                            Color="White" />
                                                    </Image.Source>
                                                </Image>
                                                <Label
                                                    FontSize="14"
                                                    Text="{Binding Item.Product.Category.Name}"
                                                    TextColor="White"
                                                    VerticalOptions="Center" />
                                            </HorizontalStackLayout>
                                        </Border>
                                        <Border
                                            Margin="0,5,0,0"
                                            Padding="6,3"
                                            BackgroundColor="{Binding Item.Quantity, Converter={converters:QuantityColorConverter}}"
                                            HorizontalOptions="Start"
                                            Stroke="{Binding Item.Quantity, Converter={converters:QuantityToStrokeColorConverter}}"
                                            StrokeShape="RoundRectangle 12">
                                            <HorizontalStackLayout Spacing="4">
                                                <Image HeightRequest="14" WidthRequest="14">
                                                    <Image.Source>
                                                        <FontImageSource
                                                            FontFamily="MaterialRegular"
                                                            Glyph="{x:Static m:MaterialRegular.Inventory_2}"
                                                            Color="White" />
                                                    </Image.Source>
                                                </Image>
                                                <Label
                                                    FontSize="14"
                                                    Text="Quantity : "
                                                    TextColor="White"
                                                    VerticalOptions="Center" />
                                                <Label
                                                    FontAttributes="Bold"
                                                    FontSize="14"
                                                    Text="{Binding Item.Quantity}"
                                                    TextColor="White"
                                                    VerticalOptions="Center" />
                                            </HorizontalStackLayout>
                                        </Border>
                                    </HorizontalStackLayout>
                                </VerticalStackLayout>
                            </Grid>
                        </Border>
                        <input:FormView
                            IsVisible="{Binding IsBusy, Converter={toolkit:InvertedBoolConverter}}"
                            Spacing="20"
                            SubmitCommand="{Binding UpdateItemSettingsCommand}">
                            <material:TextField
                                Title="Minimum Quantity"
                                AccentColor="{AppThemeBinding Dark={StaticResource BlueMunself},
                                                              Light={StaticResource Cerulean}}"
                                Icon="{FontImageSource FontFamily=MaterialRegular,
                                                       Glyph={x:Static m:MaterialRegular.Add}}"
                                Keyboard="Numeric"
                                Text="{Binding Item.MinimumQuantity, Mode=TwoWay}"
                                VerticalOptions="Center" />
                            <material:TextField
                                Title="Refill Quantity"
                                AccentColor="{AppThemeBinding Dark={StaticResource BlueMunself},
                                                              Light={StaticResource Cerulean}}"
                                Icon="{FontImageSource FontFamily=MaterialRegular,
                                                       Glyph={x:Static m:MaterialRegular.Add}}"
                                Keyboard="Numeric"
                                Text="{Binding Item.RefillQuantity, Mode=TwoWay}"
                                VerticalOptions="Center" />
                            <material:CheckBox
                                IsChecked="{Binding Item.HasAutoRefill, Mode=TwoWay}"
                                Text="Auto refill stock"
                                Color="{StaticResource YellowGreen}" />
                            <material:ButtonView
                                input:FormView.IsSubmitButton="True"
                                BackgroundColor="{StaticResource Charcoal}"
                                StyleClass="FilledButton">
                                <HorizontalStackLayout HorizontalOptions="Center" Spacing="5">
                                    <Image
                                        Aspect="AspectFit"
                                        HeightRequest="20"
                                        Source="{FontImageSource FontFamily=MaterialRegular,
                                                                 Glyph={x:Static m:MaterialRegular.Save}}"
                                        VerticalOptions="Center"
                                        WidthRequest="20" />
                                    <Label
                                        FontAttributes="Bold"
                                        Text="Save Settings"
                                        TextColor="White"
                                        VerticalOptions="Center" />
                                </HorizontalStackLayout>
                            </material:ButtonView>
                        </input:FormView>
                    </VerticalStackLayout>
                </Grid>
            </Grid>
        </VerticalStackLayout>
    </ScrollView>
</base:SfContentPage>